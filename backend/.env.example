# ===== 数据库 =====
# SQLite 文件路径（MVP 使用 SQLite，未来切 PostgreSQL 只需改此处）
DATABASE_URL=sqlite:///./travel_guide.db

# ===== JWT 认证 =====
# JWT 密钥，生产环境请改为随机长字符串。开发可用默认值。
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===== 高德地图 API =====
# 申请地址: https://lbs.amap.com/
AMAP_API_KEY=your-amap-api-key-here

# ===== 智谱 GLM API =====
# 申请地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_MODEL=glm-4

# ===== 应用 =====
APP_NAME=旅行攻略生成器
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000
