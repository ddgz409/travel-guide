# ===== 数据库 =====
# SQLite 文件路径（MVP 使用 SQLite，未来切 PostgreSQL 只需改此处）
DATABASE_URL=sqlite:///./travel_guide.db

# ===== JWT 认证 =====
# JWT 密钥，生产环境请改为随机长字符串。开发可用默认值。
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===== 高德地图 API =====
# 申请地址: https://lbs.amap.com/
AMAP_API_KEY=your-amap-api-key-here

# ===== LLM 服务器默认（智谱）=====
# 用户未在「设置」填写自己的 Key 时使用此处配置
# 申请地址: https://open.bigmodel.cn/
LLM_PROVIDER=zhipu
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_MODEL=glm-4
LLM_MODEL=glm-4

# 可选：服务器级备用 Key（用户也可在设置页自行填写）
# DOUBAO_API_KEY=   # 火山方舟 https://console.volcengine.com/ark
# MIMO_API_KEY=     # 小米 MiMo https://mimo.mi.com/
# DEEPSEEK_API_KEY=

# ===== 应用 =====
APP_NAME=旅行攻略生成器
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081,http://127.0.0.1:8081

# ===== Android 侧载更新（可选）=====
# 将 APK 放到 backend/static/android/app-release.apk
# 并编辑 backend/static/android/version.json 中的 versionCode / apkUrl / notes
